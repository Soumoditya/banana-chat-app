{
  "expo": {
    "name": "Banana Chat",
    "slug": "banana-chat",
    "version": "4.7.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "newArchEnabled": false,
    "scheme": "bananachat",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0A"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.bananachat.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Banana Chat needs camera access for video calls.",
        "NSMicrophoneUsageDescription": "Banana Chat needs microphone access for audio calls."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0A"
      },
      "edgeToEdgeEnabled": false,
      "package": "com.bananachat.app",
      "versionCode": 27,
      "permissions": [
        "CAMERA",
        "RECORD_AUDIO",
        "MODIFY_AUDIO_SETTINGS",
        "ACCESS_WIFI_STATE",
        "ACCESS_NETWORK_STATE"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24
          }
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FFD60A"
        }
      ],
      [
        "expo-dynamic-app-icon",
        {
          "spiderman": {
            "image": "./assets/images/icons/spiderman.png",
            "prerendered": true
          },
          "homelander": {
            "image": "./assets/images/icons/homelander.png",
            "prerendered": true
          },
          "ironman": {
            "image": "./assets/images/icons/ironman.png",
            "prerendered": true
          },
          "emperor_viltrum": {
            "image": "./assets/images/icons/emperor_viltrum.png",
            "prerendered": true
          },
          "ben10": {
            "image": "./assets/images/icons/ben10.png",
            "prerendered": true
          },
          "invincible": {
            "image": "./assets/images/icons/invincible.png",
            "prerendered": true
          },
          "viltrum_mark": {
            "image": "./assets/images/icons/viltrum-mark.png",
            "prerendered": true
          }
        }
      ]
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "03476d79-a927-43e1-9adc-11f1c8b20a45"
      }
    },
    "owner": "soumodityapramanik"
  }
}
